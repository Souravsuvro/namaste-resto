# ============================================================
# Namaste Gien — Environment Variables Template
# Copy this file to .env and fill in your real values
# NEVER commit the .env file — it is gitignored
# ============================================================

# Shopify
SHOPIFY_STORE_URL=namastegien.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_token_here
SHOPIFY_ADMIN_API_ACCESS_TOKEN=your_admin_token_here
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# Payment
STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx

# Restaurant (public — safe to expose in frontend)
RESTAURANT_NAME=Namaste Gien
RESTAURANT_PHONE=+33751517109
RESTAURANT_EMAIL=contact@namastegien.fr
RESTAURANT_ADDRESS=2 Pl. du Maréchal Foch, 45500 Gien, France
RESTAURANT_CITY=Gien
RESTAURANT_POSTCODE=45500
RESTAURANT_COUNTRY=FR
RESTAURANT_TIMEZONE=Europe/Paris

# Google
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Node
NODE_ENV=development
PORT=3000
